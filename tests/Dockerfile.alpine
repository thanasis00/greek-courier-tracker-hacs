# Alternative Dockerfile using Alpine Linux from GHCR
# To use this instead, rename it to Dockerfile.test

FROM ghcr.io/home-assistant/amd64-base-python:3.12-alpine3.19

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apk add --no-cache gcc musl-dev

# Install Python dependencies
RUN pip install --no-cache-dir \
    pytest==8.3.4 \
    pytest-asyncio==0.24.0 \
    pytest-cov==6.0.0 \
    beautifulsoup4==4.12.3 \
    aiohttp==3.11.11 \
    async-timeout==4.0.3

# Copy project files
COPY custom_components/ custom_components/
COPY tests/ tests/
COPY pytest.ini .

# Set the entrypoint to run tests
ENTRYPOINT ["pytest"]
CMD ["tests/", "-v", "--tb=short"]
